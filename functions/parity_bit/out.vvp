    %end;
    .scope S_0x57b1221d51d0;
T_1 ;
    %pushi/vec4 170, 0, 8;
    %store/vec4 v0x57b1221f8a70_0, 0, 8;
    %load/vec4 v0x57b1221f8a70_0;
    %store/vec4 v0x57b1221d5540_0, 0, 8;
    %callf/vec4 TD_parity_big.get_parity, S_0x57b1221d5360;
    %store/vec4 v0x57b1221f8b70_0, 0, 1;
    %vpi_call 2 22 "$display", "data_in = %b | parity_out = %b", v0x57b1221f8a70_0, v0x57b1221f8b70_0 {0 0 0};
    %pushi/vec4 171, 0, 8;
