    ; show_stmt_assign_vector: Get l-value for compressed += operand
    %load/vec4 v0x57b1221f88f0_0;
    %pushi/vec4 1, 0, 32;
    %add;
    %store/vec4 v0x57b1221f88f0_0, 0, 32;
